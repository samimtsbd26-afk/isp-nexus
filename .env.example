# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Ports ────────────────────────────────────────────────────────────────────
PORT_API=3001
PORT_WEB=3000
PORT_PORTAL=3002

# ─── Public URLs (skynity.org) ────────────────────────────────────────────────
APP_URL=https://admin.skynity.org
API_URL=https://api.skynity.org
PORTAL_URL=https://wifi.skynity.org
HOTSPOT_URL=https://hotspot.skynity.org
HOTSPOT_DNS_NAME=hotspot.skynity.org

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=isp_nexus
POSTGRES_USER=isp_nexus_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgres://isp_nexus_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/isp_nexus

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_FOR_AES256
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Portal customers use a separate signing key
PORTAL_JWT_SECRET=CHANGE_ME_PORTAL_64_CHAR_HEX

# ─── FreeRADIUS ───────────────────────────────────────────────────────────────
RADIUS_HOST=freeradius
RADIUS_SECRET=CHANGE_ME_RADIUS_SECRET
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ─── MikroTik defaults ────────────────────────────────────────────────────────
MIKROTIK_DEFAULT_API_PORT=8728
MIKROTIK_DEFAULT_SSL_PORT=8729
MIKROTIK_API_TIMEOUT_MS=5000
MIKROTIK_MOCK=false

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_CUSTOMER_BOT_TOKEN=YOUR_CUSTOMER_BOT_TOKEN
TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# ─── Payments (bKash / Nagad / Rocket) ───────────────────────────────────────
BKASH_NUMBER=01XXXXXXXXX
NAGAD_NUMBER=01XXXXXXXXX
ROCKET_NUMBER=01XXXXXXXXX
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_WEBHOOK_SECRET=
NAGAD_WEBHOOK_SECRET=

# ─── WireGuard (Starlink CGNAT bypass) ───────────────────────────────────────
WG_INTERFACE=wg0
WG_SERVER_IP=10.100.0.1/24
WG_LISTEN_PORT=51820
WG_DNS=1.1.1.1,8.8.8.8

# ─── SSL (Caddy auto-manages via ACME / Let's Encrypt) ───────────────────────
SSL_EMAIL=admin@skynity.org

# ─── Bootstrap (first run only) ──────────────────────────────────────────────
BOOTSTRAP_ORG_NAME=Skynity ISP
BOOTSTRAP_ADMIN_EMAIL=admin@skynity.org
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── PGAdmin (optional, tools profile) ───────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@skynity.org
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
