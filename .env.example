# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Ports ────────────────────────────────────────────────────────────────────
PORT_API=3001
PORT_WEB=3000
PORT_PORTAL=3002

# ─── Public URLs (skynity.org) ────────────────────────────────────────────────
APP_URL=https://admin.skynity.org
API_URL=https://api.skynity.org
PORTAL_URL=https://wifi.skynity.org
HOTSPOT_URL=https://hotspot.skynity.org
HOTSPOT_DNS_NAME=hotspot.skynity.org

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=isp_nexus
POSTGRES_USER=isp_nexus_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgres://isp_nexus_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/isp_nexus
# If host `pnpm db:migrate` fails auth: POSTGRES_PASSWORD must match the password from the first Postgres start (volume postgres_data). Align user/password in DATABASE_URL, or `docker compose down -v` for a fresh DB (data loss).

# Host-only: optional explicit URL for `pnpm db:migrate` / `pnpm db:seed`.
# DATABASE_URL_MIGRATE=postgres://isp_nexus_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/isp_nexus

# CLI tools prefer POSTGRES_* (above) → URL on 127.0.0.1 for host; override host with POSTGRES_HOST_MIGRATE=...
# Inside a migration container only: DRIZZLE_DOCKER_INTERNAL=1

# Production migrations: Compose `db-migrator` is canonical — it runs packages/db/migrations/*.sql then baseline-syncs `drizzle.__drizzle_migrations`.
# Avoid running host `pnpm db:migrate` against prod until that ledger matches; duplicate enum/type errors usually mean Drizzle ledger was empty (re-run/db-migrator image).
# Deploy gate: `pnpm env:check` (strict). Local only: SKIP_ENV_CHECK=1 to skip validator.

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_FOR_AES256
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Portal customers use a separate signing key
PORTAL_JWT_SECRET=CHANGE_ME_PORTAL_64_CHAR_HEX
PORTAL_JWT_EXPIRES=7d
# UUID of the default organization used by the captive portal REST endpoints
# Run: SELECT id FROM organizations LIMIT 1; to get this value after first setup
PORTAL_ORG_ID=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. Can be overridden per-org via admin panel.
CORS_ORIGINS=https://admin.skynity.org,https://wifi.skynity.org,https://hotspot.skynity.org

# ─── Caddy Admin API ──────────────────────────────────────────────────────────
# Internal Docker URL — never expose port 2019 to the public internet.
# In Docker: http://caddy:2019 | Local dev: http://localhost:2019
CADDY_ADMIN_URL=http://caddy:2019

# ─── VPS SSH (stored encrypted in DB — set via Admin Panel → Infrastructure) ──
# SSH credentials are NOT stored in .env — add them via the admin panel after first deploy.
# The panel uses AES-256-GCM to encrypt private keys/passwords before DB storage.

# ─── FreeRADIUS ───────────────────────────────────────────────────────────────
RADIUS_HOST=freeradius
RADIUS_SECRET=CHANGE_ME_RADIUS_SECRET
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ─── MikroTik defaults ────────────────────────────────────────────────────────
MIKROTIK_DEFAULT_API_PORT=8728
MIKROTIK_DEFAULT_SSL_PORT=8729
MIKROTIK_API_TIMEOUT_MS=5000
MIKROTIK_MOCK=false

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_CUSTOMER_BOT_TOKEN=YOUR_CUSTOMER_BOT_TOKEN
TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# ─── Payments (bKash / Nagad / Rocket) ───────────────────────────────────────
BKASH_NUMBER=01XXXXXXXXX
NAGAD_NUMBER=01XXXXXXXXX
ROCKET_NUMBER=01XXXXXXXXX
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_WEBHOOK_SECRET=
NAGAD_WEBHOOK_SECRET=

# ─── WireGuard (Starlink CGNAT bypass) ───────────────────────────────────────
WG_INTERFACE=wg0
WG_SERVER_IP=10.100.0.1/24
WG_LISTEN_PORT=51820
WG_DNS=1.1.1.1,8.8.8.8

# ─── SSL (Caddy auto-manages via ACME / Let's Encrypt) ───────────────────────
SSL_EMAIL=admin@skynity.org

# ─── Bootstrap (first run only) ──────────────────────────────────────────────
BOOTSTRAP_ORG_NAME=Skynity ISP
BOOTSTRAP_ADMIN_EMAIL=admin@skynity.org
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── PGAdmin (optional, tools profile) ───────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@skynity.org
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
