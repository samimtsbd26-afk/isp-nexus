{
  "name": "isp-nexus",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade ISP management system — MikroTik, PPPoE, Hotspot, Billing, RADIUS",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@isp-nexus/db",
    "db:migrate": "turbo run db:migrate --filter=@isp-nexus/db",
    "db:seed": "turbo run db:seed --filter=@isp-nexus/db",
    "env:ensure": "node scripts/ensure-env-from-example.mjs",
    "env:check": "node scripts/check-production-env.mjs --strict",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "ssh2": "^1.17.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
