# ISP Nexus Mobile — environment variables
# Copy to .env and fill in

# API base URL (no trailing slash)
EXPO_PUBLIC_API_BASE=https://api.skynity.org

# Organization ID (portal will auto-detect via settings, but can be hardcoded for single-tenant)
EXPO_PUBLIC_ORG_ID=

# Push notification — set after creating FCM project
EXPO_PUBLIC_FCM_SENDER_ID=
