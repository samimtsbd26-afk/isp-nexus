    "expo-network": "~7.0.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "~4.4.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.0",
